<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recibo <%= numeroRecibo %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .recibo {
            background: white;
            max-width: 600px;
            width: 100%;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #667eea;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }
        .header h1 {
            color: #333;
            font-size: 26px;
        }
        .header p {
            color: #666;
            font-size: 14px;
        }
        
        .info-cliente {
            background: #f8f9fa;
            padding: 15px 20px;
            border-radius: 12px;
            margin-bottom: 25px;
        }
        .info-cliente .fila {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px solid #e9ecef;
        }
        .info-cliente .fila:last-child {
            border-bottom: none;
        }
        .info-cliente .label {
            font-weight: 600;
            color: #555;
        }
        .info-cliente .valor {
            color: #333;
            text-align: right;
        }

        .tabla {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }
        .tabla th {
            text-align: left;
            padding: 10px;
            border-bottom: 2px solid #667eea;
            color: #333;
        }
        .tabla td {
            padding: 10px;
            border-bottom: 1px solid #e9ecef;
        }
        .tabla .monto {
            text-align: right;
        }
        .tabla .total {
            font-weight: bold;
            font-size: 18px;
        }

        .balance-pendiente {
            text-align: right;
            font-size: 22px;
            font-weight: bold;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 10px;
            margin: 15px 0;
        }
        .balance-pendiente .importe {
            color: #dc3545;
        }
        .balance-pendiente .importe.pagado {
            color: #28a745;
        }

        .estado-pago {
            text-align: center;
            padding: 18px;
            border-radius: 12px;
            margin: 20px 0;
            border: 3px solid #28a745;
            background: #d4edda;
        }
        .estado-pago .texto {
            font-size: 26px;
            font-weight: bold;
            color: #155724;
        }

        .mensaje-proveedor {
            text-align: center;
            padding: 15px;
            border-radius: 10px;
            margin: 15px 0;
            font-size: 20px;
            font-weight: bold;
        }
        .mensaje-proveedor.pagado {
            background: #d4edda;
            border: 2px solid #28a745;
            color: #155724;
        }
        .mensaje-proveedor.pendiente {
            background: #fff3cd;
            border: 2px solid #ffc107;
            color: #856404;
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px solid #e9ecef;
            color: #999;
            font-size: 12px;
        }
        .btn {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 10px 30px;
            border-radius: 50px;
            text-decoration: none;
            margin-top: 15px;
        }
        .btn:hover {
            background: #5563c1;
        }
    </style>
</head>
<body>
    <div class="recibo">
        <div class="header">
            <h1>🧾 REPUBLIC EXCURSIONS</h1>
            <p>Comprobante de pago</p>
        </div>

        <div class="info-cliente">
            <div class="fila">
                <span class="label">Factura:</span>
                <span class="valor"><%= idFactura %></span>
            </div>
            <div class="fila">
                <span class="label">Cliente:</span>
                <span class="valor"><%= cliente %></span>
            </div>
            <div class="fila">
                <span class="label">Excursión:</span>
                <span class="valor"><%= excursion %></span>
            </div>
            <div class="fila">
                <span class="label">Fecha:</span>
                <span class="valor"><%= fecha %></span>
            </div>
            <div class="fila">
                <span class="label">Personas:</span>
                <span class="valor"><%= adultos %> Adultos, <%= ninos %> Niños</span>
            </div>
            <div class="fila">
                <span class="label">Método de Pago:</span>
                <span class="valor"><%= metodoPago %></span>
            </div>
        </div>

        <table class="tabla">
            <thead>
                <tr>
                    <th>Concepto</th>
                    <th class="monto">Monto (USD)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong><%= excursion %></strong></td>
                    <td class="monto"></td>
                </tr>
                <tr>
                    <td>Adultos: <%= adultos %> × $<%= precioAdulto.toFixed(2) %></td>
                    <td class="monto">$<%= (adultos * precioAdulto).toFixed(2) %></td>
                </tr>
                <tr>
                    <td><strong>Subtotal</strong></td>
                    <td class="monto"><strong>$<%= subtotal.toFixed(2) %></strong></td>
                </tr>
                <tr>
                    <td>Depósito Pagado (25%)</td>
                    <td class="monto">$<%= depositoPagado.toFixed(2) %></td>
                </tr>
            </tbody>
        </table>

        <div class="balance-pendiente">
            <span>Balance Pendiente:</span>
            <span class="importe <%= totalPendiente === 0 ? 'pagado' : '' %>">
                $<%= totalPendiente.toFixed(2) %>
            </span>
        </div>

        <div class="estado-pago" style="border-color: <%= estadoColor %>; background: <%= estadoColor %>15;">
            <div class="texto" style="color: <%= estadoColor %>;">
                <%= estadoTexto %>
            </div>
        </div>

        <!-- ⭐ MENSAJE CONDICIONAL -->
        <% if (totalPendiente > 0) { %>
            <div class="mensaje-proveedor pendiente">
                ⚠️ Falta pagar: $<%= totalPendiente.toFixed(2) %>
            </div>
        <% } else { %>
            <div class="mensaje-proveedor pagado">
                ✅ Saldo: $0.00 - Todo pagado
            </div>
        <% } %>

        <div class="footer">
            <p>© 2026 - Republic Excursions</p>
            <a href="/" class="btn">Volver al inicio</a>
        </div>
    </div>
</body>
</html>
