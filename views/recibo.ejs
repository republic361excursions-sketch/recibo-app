<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#1a2a4a">
    <title>Recibo <%= numeroRecibo %> | Republic Excursions</title>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }
        .recibo {
            background: #ffffff;
            max-width: 820px;
            width: 100%;
            padding: 50px 55px;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
            border: 1px solid #e8eaed;
            margin-bottom: 30px;
            transition: box-shadow 0.3s ease;
        }
        .recibo:hover { box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12); }
        .header {
            text-align: center;
            border-bottom: 3px solid #1a2a4a;
            padding-bottom: 25px;
            margin-bottom: 30px;
        }
        .header .logo {
            font-size: 24px;
            font-weight: 700;
            color: #1a2a4a;
            letter-spacing: 4px;
            text-transform: uppercase;
        }
        .header .logo span { color: #c9a84c; }
        .header .titulo {
            font-size: 28px;
            font-weight: 300;
            color: #2c3e50;
            margin-top: 6px;
            letter-spacing: 2px;
        }
        .header .recibo-numero {
            font-size: 14px;
            color: #8e9aaf;
            margin-top: 6px;
            font-weight: 400;
            letter-spacing: 0.5px;
        }

        .expiracion-info {
            display: flex;
            justify-content: space-around;
            padding: 16px 20px;
            border-radius: 10px;
            margin: 16px 0 24px 0;
            border: 1px solid #a5d6a7;
            background: #e8f5e9;
        }
        .expiracion-info.permanente {
            background: #e3f2fd;
            border-color: #64b5f6;
        }
        .expiracion-info.expirado {
            background: #ffebee;
            border-color: #ef9a9a;
        }
        .expiracion-item { text-align: center; }
        .expiracion-item .label {
            display: block;
            font-size: 11px;
            color: #6b7a8f;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .expiracion-item .valor {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #1a2a4a;
            margin-top: 4px;
        }
        .expiracion-item .valor.expirado { color: #c62828; }
        .expiracion-item .valor.valido { color: #2e7d32; }
        .expiracion-item .valor.permanente { color: #0d47a1; }

        .info-cliente {
            margin-bottom: 30px;
            padding: 20px 28px;
            background: #f8f9fa;
            border-radius: 12px;
            border-left: 5px solid #c9a84c;
        }
        .info-cliente .titulo {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #8e9aaf;
            font-weight: 600;
            margin-bottom: 12px;
            border-bottom: 1px solid #e8eaed;
            padding-bottom: 8px;
        }
        .info-cliente .fila {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 14px;
            color: #2c3e50;
            border-bottom: 1px solid #f0f0f0;
        }
        .info-cliente .fila:last-child { border-bottom: none; }
        .info-cliente .label { font-weight: 500; color: #6b7a8f; }
        .info-cliente .valor { font-weight: 400; text-align: right; color: #1a2a4a; }

        .tabla-container { overflow-x: auto; margin: 25px 0; }
        .tabla {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            border-bottom: 2px solid #1a2a4a;
        }
        .tabla th {
            text-align: left;
            padding: 12px 0;
            border-bottom: 2px solid #1a2a4a;
            color: #1a2a4a;
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .tabla td {
            padding: 10px 0;
            border-bottom: 1px solid #e8eaed;
            color: #2c3e50;
        }
        .tabla .monto { text-align: right; font-weight: 500; }
        .tabla .total { font-weight: 600; font-size: 15px; }

        .estado-unico {
            text-align: center;
            padding: 18px 24px;
            border-radius: 10px;
            margin: 25px 0;
            font-size: 22px;
            font-weight: 600;
            letter-spacing: 1px;
        }
        .estado-unico.pagado {
            background: #e8f5e9;
            border: 2px solid #2e7d32;
            color: #1b5e20;
        }
        .estado-unico.falta {
            background: #fff8e1;
            border: 2px solid #f9a825;
            color: #e65100;
        }
        .estado-unico.pendiente {
            background: #ffebee;
            border: 2px solid #c62828;
            color: #b71c1c;
        }

        .resumen-pago {
            background: #f8f9fa;
            padding: 20px 28px;
            border-radius: 12px;
            margin: 20px 0;
        }
        .resumen-pago .fila {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid #e8eaed;
            font-size: 14px;
        }
        .resumen-pago .fila:last-child { border-bottom: none; }
        .resumen-pago .label { font-weight: 500; color: #6b7a8f; }
        .resumen-pago .value { font-weight: 600; color: #1a2a4a; }
        .resumen-pago .value.pendiente { color: #c62828; }
        .resumen-pago .value.pagado { color: #2e7d32; }
        .resumen-pago .fila.total {
            border-top: 2px solid #1a2a4a;
            padding-top: 10px;
            margin-top: 6px;
            font-size: 15px;
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e8eaed;
            color: #aab3c5;
            font-size: 12px;
            letter-spacing: 0.5px;
        }
        .footer .empresa {
            color: #1a2a4a;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 2px;
        }
        .footer .direccion {
            margin-top: 4px;
            font-size: 12px;
            color: #b0bec5;
        }
        .footer .codigo {
            margin-top: 8px;
            font-size: 11px;
            color: #b0bec5;
            letter-spacing: 0.5px;
        }
        .qr-info {
            text-align: center;
            margin: 16px 0;
            padding: 12px;
            background: #f8f9fa;
            border-radius: 10px;
            font-size: 12px;
            color: #8e9aaf;
        }
        .qr-info span { font-weight: 600; color: #1a2a4a; }

        .acciones-recibo {
            display: none;
            flex-wrap: wrap;
            gap: 14px;
            justify-content: center;
            max-width: 820px;
            width: 100%;
            margin-top: 15px;
        }
        .acciones-recibo.visible { display: flex; }
        .btn-accion {
            padding: 14px 32px;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            background: #1a2a4a;
            color: #ffffff;
            letter-spacing: 0.5px;
        }
        .btn-accion:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }
        .btn-accion.whatsapp { background: #25D366; }
        .btn-accion.whatsapp:hover { background: #1da851; }
        .btn-accion.imagen { background: #c9a84c; }
        .btn-accion.imagen:hover { background: #b8973a; }
        .btn-accion.volver { background: #78909c; }
        .btn-accion.volver:hover { background: #607d8b; }

        @media print {
            body { background: #ffffff; padding: 0; }
            .recibo { box-shadow: none; border: 1px solid #ddd; padding: 30px; }
            .acciones-recibo { display: none !important; }
        }
        @media (max-width: 640px) {
            .recibo { padding: 25px 20px; }
            .expiracion-info { flex-direction: column; gap: 8px; }
            .expiracion-item { display: flex; justify-content: space-between; padding: 2px 0; }
            .expiracion-item .label { font-size: 12px; }
            .expiracion-item .valor { font-size: 13px; }
            .info-cliente .fila { flex-direction: column; align-items: flex-start; }
            .info-cliente .valor { text-align: left; width: 100%; }
            .tabla { font-size: 13px; }
            .estado-unico { font-size: 18px; padding: 14px; }
            .acciones-recibo { flex-direction: column; align-items: center; }
            .btn-accion { width: 100%; text-align: center; }
        }
    </style>
</head>
<body>

    <div id="reciboContainer" class="recibo">
        
        <div class="header">
            <div class="logo">Republic <span>Excursions</span></div>
            <div class="titulo">Recibo de Pago</div>
            <div class="recibo-numero">Recibo # <%= numeroRecibo %></div>
        </div>

        <% if (fechaGeneracion && fechaExpiracion) { %>
            <div class="expiracion-info <%= reciboValido ? '' : 'expirado' %>">
                <div class="expiracion-item">
                    <span class="label">Generado</span>
                    <span class="valor"><%= new Date(fechaGeneracion).toLocaleString('es-ES') %></span>
                </div>
                <div class="expiracion-item">
                    <span class="label">Válido hasta</span>
                    <span class="valor"><%= new Date(fechaExpiracion).toLocaleString('es-ES') %></span>
                </div>
                <div class="expiracion-item">
                    <span class="label">Estado</span>
                    <span class="valor <%= reciboValido ? 'valido' : 'expirado' %>">
                        <%= reciboValido ? 'Válido' : 'Expirado' %>
                    </span>
                </div>
                <div class="expiracion-item">
                    <span class="label">Válido por</span>
                    <span class="valor"><%= textoExpiracion %></span>
                </div>
            </div>
        <% } else if (expiracionConfig === 'nunca') { %>
        <div class="expiracion-info permanente">
            <div class="expiracion-item" style="flex: 1;">
                <span class="label">Estado del QR</span>
                <span class="valor permanente">Válido permanentemente</span>
            </div>
            <div class="expiracion-item" style="flex: 1;">
                <span class="label">Tipo</span>
                <span class="valor permanente">Sin expiración</span>
            </div>
        </div>
        <% } %>

        <div class="info-cliente">
            <div class="titulo">Información de la Reserva</div>
            <div class="fila">
                <span class="label">Factura / Reserva</span>
                <span class="valor"><%= idFactura %></span>
            </div>
            <div class="fila">
                <span class="label">Cliente</span>
                <span class="valor"><%= cliente %></span>
            </div>
            <div class="fila">
                <span class="label">Tipo de Excursión</span>
                <span class="valor"><%= tipoExcursion === 'privado' ? 'Privado' : 'Compartido' %></span>
            </div>
            <% if (grupo) { %>
            <div class="fila">
                <span class="label">Grupo</span>
                <span class="valor"><%= grupo %></span>
            </div>
            <% } %>
            <% if (whatsapp) { %>
            <div class="fila">
                <span class="label">WhatsApp</span>
                <span class="valor"><%= whatsapp %></span>
            </div>
            <% } %>
            <% if (correo) { %>
            <div class="fila">
                <span class="label">Correo Electrónico</span>
                <span class="valor"><%= correo %></span>
            </div>
            <% } %>
            <div class="fila">
                <span class="label"><%= esSinRecogida ? 'Lugar de la Excursión' : 'Recogida' %></span>
                <span class="valor">
                    <% if (esSinRecogida) { %>
                        <%= lugarRecogida || '---' %>
                    <% } else { %>
                        <%= tipoRecogida %><%= lugarRecogida ? ' - ' + lugarRecogida : '' %>
                    <% } %>
                </span>
            </div>
            <% if (!esSinRecogida) { %>
            <div class="fila">
                <span class="label"><%= tipoRecogida === 'Hotel' ? 'Habitación' : tipoRecogida === 'Airbnb' ? 'Apartamento' : 'Referencia' %></span>
                <span class="valor"><%= habitacion || '---' %></span>
            </div>
            <% } %>
            <div class="fila">
                <span class="label"><%= labelHora %></span>
                <span class="valor"><%= horaRecogida || '---' %></span>
            </div>
            <div class="fila">
                <span class="label">Transporte</span>
                <span class="valor"><%= transporte %></span>
            </div>
            <div class="fila">
                <span class="label">Excursión</span>
                <span class="valor"><%= excursion %></span>
            </div>
            <div class="fila">
                <span class="label">Fecha</span>
                <span class="valor"><%= fechaExcursion %></span>
            </div>
            <div class="fila">
                <span class="label">Personas</span>
                <span class="valor"><%= adultos %> Adultos, <%= ninos %> Niños</span>
            </div>
            <% if (capacidadMaxima) { %>
            <div class="fila">
                <span class="label">Capacidad Máxima</span>
                <span class="valor"><%= capacidadMaxima %></span>
            </div>
            <% } %>
            <div class="fila">
                <span class="label">Método de Pago</span>
                <span class="valor"><%= metodoPago %></span>
            </div>
            <% if (notas && notas !== 'Sin notas adicionales') { %>
            <div class="fila">
                <span class="label">Notas</span>
                <span class="valor"><%= notas %></span>
            </div>
            <% } %>
        </div>

        <div class="tabla-container">
            <table class="tabla">
                <thead>
                    <tr>
                        <th>Concepto</th>
                        <th class="monto">Monto (USD)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong><%= excursion %></strong></td>
                        <td class="monto"></td>
                    </tr>
                    <% if (tipoExcursion === 'compartido') { %>
                    <tr>
                        <td>Adultos: <%= adultos %> × $<%= precioAdulto.toFixed(2) %></td>
                        <td class="monto">$<%= (adultos * precioAdulto).toFixed(2) %></td>
                    </tr>
                    <% if (ninos > 0) { %>
                    <tr>
                        <td>Niños: <%= ninos %> × $<%= precioNino.toFixed(2) %></td>
                        <td class="monto">$<%= (ninos * precioNino).toFixed(2) %></td>
                    </tr>
                    <% } %>
                    <% } else { %>
                    <tr>
                        <td>Privado - <%= adultos %> personas</td>
                        <td class="monto">$<%= precioAdulto.toFixed(2) %></td>
                    </tr>
                    <% } %>
                    <tr>
                        <td><strong>Subtotal</strong></td>
                        <td class="monto total">$<%= subtotal.toFixed(2) %></td>
                    </tr>
                    <% if (descuento > 0) { %>
                    <tr>
                        <td style="color: #2e7d32;"><strong>Descuento</strong></td>
                        <td class="monto" style="color: #2e7d32;">-$<%= descuento.toFixed(2) %></td>
                    </tr>
                    <tr>
                        <td><strong>Total</strong></td>
                        <td class="monto total">$<%= total.toFixed(2) %></td>
                    </tr>
                    <% } %>
                    <% if (depositoPagado > 0 && totalPendiente > 0) { %>
                    <tr>
                        <td>Depósito Pagado (25%)</td>
                        <td class="monto">$<%= depositoPagado.toFixed(2) %></td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <%
            let estadoClase = '';
            let estadoMostrar = '';
            if (totalPendiente <= 0) {
                estadoClase = 'pagado';
                estadoMostrar = 'PAGADO COMPLETO';
            } else if (estado === 'deposito' && depositoPagado > 0) {
                estadoClase = 'falta';
                estadoMostrar = 'DEPÓSITO PAGADO - Falta: $' + totalPendiente.toFixed(2);
            } else {
                estadoClase = 'pendiente';
                estadoMostrar = 'PENDIENTE DE PAGO - Total: $' + totalPendiente.toFixed(2);
            }
        %>
        <div class="estado-unico <%= estadoClase %>">
            <%= estadoMostrar %>
        </div>

        <div class="resumen-pago">
            <div class="fila">
                <span class="label">Subtotal</span>
                <span class="value">$<%= subtotal.toFixed(2) %></span>
            </div>
            <% if (descuento > 0) { %>
            <div class="fila">
                <span class="label">Descuento</span>
                <span class="value" style="color: #2e7d32;">-$<%= descuento.toFixed(2) %></span>
            </div>
            <div class="fila">
                <span class="label">Total</span>
                <span class="value">$<%= total.toFixed(2) %></span>
            </div>
            <% } %>
            <% if (depositoPagado > 0 && totalPendiente > 0) { %>
            <div class="fila">
                <span class="label">Depósito Pagado (25%)</span>
                <span class="value">$<%= depositoPagado.toFixed(2) %></span>
            </div>
            <% } %>
            <div class="fila total">
                <span class="label">Balance Pendiente</span>
                <span class="value <%= totalPendiente === 0 ? 'pagado' : 'pendiente' %>">
                    $<%= totalPendiente.toFixed(2) %>
                    <% if (totalPendiente === 0) { %>
                        <span style="font-size: 12px; color: #2e7d32;"> (Pagado)</span>
                    <% } %>
                </span>
            </div>
        </div>

        <div class="qr-info">
            <span>Documento de verificación</span> &mdash; Código <%= numeroRecibo %>
        </div>

        <div class="footer">
            <p class="empresa">Republic Excursions</p>
            <p class="direccion">Punta Cana, República Dominicana</p>
            <p><%= fecha %></p>
            <p class="codigo">Este documento es un comprobante de pago válido</p>
        </div>
    </div>

    <% if (mostrarBotones) { %>
    <div class="acciones-recibo visible">
        <button class="btn-accion imagen" onclick="descargarImagen()">Descargar Imagen</button>
        <a href="#" class="btn-accion whatsapp" id="whatsappBtn">Enviar por WhatsApp</a>
        <a href="/" class="btn-accion volver">Volver al inicio</a>
    </div>
    <% } %>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var cliente = '<%= cliente %>';
            var excursion = '<%= excursion %>';
            var enlace = window.location.href;
            var mensaje = 'Hola ' + cliente + ', tu recibo de ' + excursion + ' está listo. Puedes verlo aquí: ' + enlace;
            var whatsappBtn = document.getElementById('whatsappBtn');
            if (whatsappBtn) {
                whatsappBtn.href = 'https://wa.me/1?text=' + encodeURIComponent(mensaje);
            }
        });

        function descargarImagen() {
            var elemento = document.getElementById('reciboContainer');
            var btn = document.querySelector('.btn-accion.imagen');
            var textoOriginal = btn.innerHTML;
            btn.innerHTML = 'Generando...';
            btn.disabled = true;

            html2canvas(elemento, {
                scale: 2,
                backgroundColor: '#ffffff',
                useCORS: true,
                allowTaint: true,
                logging: false
            })
            .then(function(canvas) {
                var link = document.createElement('a');
                var reciboNum = document.querySelector('.recibo-numero')
                    .textContent
                    .trim()
                    .replace(/\s/g, '');
                link.download = 'recibo-' + reciboNum + '.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
                btn.innerHTML = textoOriginal;
                btn.disabled = false;
            })
            .catch(function(error) {
                console.error('Error al generar la imagen:', error);
                btn.innerHTML = 'Error';
                btn.disabled = false;
                setTimeout(function() {
                    btn.innerHTML = textoOriginal;
                }, 3000);
            });
        }
    </script>

</body>
</html>
