<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recibo <%= numeroRecibo %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .recibo {
            background: white;
            max-width: 700px;
            width: 100%;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        .header {
            text-align: center;
            border-bottom: 2px solid #1a3c6e;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }
        .header h1 {
            color: #1a3c6e;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        .header h2 {
            color: #333;
            font-size: 18px;
            font-weight: 600;
            margin-top: 5px;
        }
        .header .recibo-numero {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }
        .info-cliente {
            background: #f8f9fa;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 20px;
        }
        .info-cliente .titulo {
            font-weight: 700;
            color: #1a3c6e;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            border-bottom: 2px solid #1a3c6e;
            padding-bottom: 5px;
        }
        .info-cliente .fila {
            display: flex;
            justify-content: space-between;
            padding: 4px 0;
            border-bottom: 1px solid #e9ecef;
        }
        .info-cliente .fila:last-child {
            border-bottom: none;
        }
        .info-cliente .label {
            font-weight: 600;
            color: #555;
            font-size: 13px;
        }
        .info-cliente .valor {
            color: #333;
            text-align: right;
            font-size: 13px;
        }
        .tabla {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            font-size: 14px;
        }
        .tabla th {
            text-align: left;
            padding: 10px;
            border-bottom: 2px solid #1a3c6e;
            color: #333;
            font-weight: 700;
        }
        .tabla td {
            padding: 10px;
            border-bottom: 1px solid #e9ecef;
        }
        .tabla .monto {
            text-align: right;
            font-weight: 600;
        }
        .tabla .total {
            font-weight: 700;
            font-size: 16px;
        }
        .tabla .descuento {
            color: #28a745;
        }
        .balance-pendiente {
            text-align: center;
            font-size: 20px;
            font-weight: 700;
            padding: 15px;
            border-radius: 6px;
            margin: 15px 0;
            background: #fff3cd;
            border: 2px solid #ffc107;
        }
        .balance-pendiente .importe {
            color: #dc3545;
            font-size: 24px;
        }
        .balance-pendiente .importe.pagado {
            color: #28a745;
        }
        .balance-pendiente .label {
            display: block;
            font-size: 14px;
            color: #856404;
            font-weight: 600;
        }
        .mensaje-falta-pagar {
            text-align: center;
            padding: 18px;
            border-radius: 6px;
            margin: 15px 0;
            font-size: 22px;
            font-weight: 700;
        }
        .mensaje-falta-pagar.pendiente {
            background: #fff3cd;
            border: 2px solid #ffc107;
            color: #856404;
        }
        .mensaje-falta-pagar.pagado {
            background: #d4edda;
            border: 2px solid #28a745;
            color: #155724;
        }
        .mensaje-falta-pagar .monto {
            font-size: 28px;
        }
        .estado-pago {
            text-align: center;
            padding: 15px;
            border-radius: 6px;
            margin: 20px 0;
            border: 2px solid #28a745;
            background: #d4edda;
        }
        .estado-pago .texto {
            font-size: 20px;
            font-weight: 700;
            color: #155724;
        }
        .resumen-pago {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 6px;
            margin: 15px 0;
        }
        .resumen-pago .fila {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid #e9ecef;
            font-size: 14px;
        }
        .resumen-pago .fila:last-child {
            border-bottom: none;
        }
        .resumen-pago .label {
            font-weight: 600;
            color: #555;
        }
        .resumen-pago .value {
            font-weight: 700;
        }
        .resumen-pago .value.pendiente {
            color: #dc3545;
        }
        .resumen-pago .value.pagado {
            color: #28a745;
        }
        .resumen-pago .fila.total {
            border-top: 2px solid #1a3c6e;
            padding-top: 10px;
            margin-top: 5px;
            font-size: 16px;
        }
        .resumen-pago .fila.descuento .value {
            color: #28a745;
        }
        .footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px solid #e9ecef;
            color: #999;
            font-size: 11px;
        }
        .footer .empresa {
            color: #1a3c6e;
            font-weight: 700;
            font-size: 12px;
        }
        .qr-info {
            text-align: center;
            margin: 15px 0;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 6px;
            font-size: 12px;
            color: #666;
        }
        .qr-info span {
            font-weight: 700;
            color: #1a3c6e;
        }
        @media print {
            body { background: white; padding: 0; }
            .recibo { box-shadow: none; border: 1px solid #ddd; }
        }
    </style>
</head>
<body>
    <div class="recibo">
        <div class="header">
            <h1>REPUBLIC EXCURSIONS</h1>
            <h2>RECIBO DE PAGO</h2>
            <p class="recibo-numero">Recibo #: <%= numeroRecibo %></p>
        </div>

        <div class="info-cliente">
            <div class="titulo">DATOS DE LA RESERVA</div>
            <div class="fila">
                <span class="label">Factura / Reserva:</span>
                <span class="valor"><%= idFactura %></span>
            </div>
            <div class="fila">
                <span class="label">Cliente:</span>
                <span class="valor"><%= cliente %></span>
            </div>
            <% if (whatsapp) { %>
            <div class="fila">
                <span class="label">WhatsApp:</span>
                <span class="valor"><%= whatsapp %></span>
            </div>
            <% } %>
            <% if (correo) { %>
            <div class="fila">
                <span class="label">Correo:</span>
                <span class="valor"><%= correo %></span>
            </div>
            <% } %>
            <% if (hotel) { %>
            <div class="fila">
                <span class="label">Hotel:</span>
                <span class="valor"><%= hotel %></span>
            </div>
            <% } %>
            <% if (habitacion) { %>
            <div class="fila">
                <span class="label">Habitación:</span>
                <span class="valor"><%= habitacion %></span>
            </div>
            <% } %>
            <div class="fila">
                <span class="label">Excursión:</span>
                <span class="valor"><%= excursion %></span>
            </div>
            <div class="fila">
                <span class="label">Fecha:</span>
                <span class="valor"><%= fechaExcursion %></span>
            </div>
            <div class="fila">
                <span class="label">Personas:</span>
                <span class="valor"><%= adultos %> Adultos, <%= ninos %> Niños</span>
            </div>
            <div class="fila">
                <span class="label">Transporte:</span>
                <span class="valor"><%= transporte %></span>
            </div>
            <div class="fila">
                <span class="label">Método de Pago:</span>
                <span class="valor"><%= metodoPago %></span>
            </div>
            <% if (notas && notas !== 'Sin notas adicionales') { %>
            <div class="fila">
                <span class="label">Notas:</span>
                <span class="valor"><%= notas %></span>
            </div>
            <% } %>
        </div>

        <table class="tabla">
            <thead>
                <tr>
                    <th>Concepto</th>
                    <th class="monto">Monto (USD)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong><%= excursion %></strong></td>
                    <td class="monto"></td>
                </tr>
                <tr>
                    <td>Adultos: <%= adultos %> × $<%= precioAdulto.toFixed(2) %></td>
                    <td class="monto">$<%= (adultos * precioAdulto).toFixed(2) %></td>
                </tr>
                <% if (ninos > 0) { %>
                <tr>
                    <td>Niños: <%= ninos %> × $<%= precioNino.toFixed(2) %></td>
                    <td class="monto">$<%= (ninos * precioNino).toFixed(2) %></td>
                </tr>
                <% } %>
                <tr>
                    <td><strong>Subtotal</strong></td>
                    <td class="monto"><strong>$<%= subtotal.toFixed(2) %></strong></td>
                </tr>
                <% if (descuento > 0) { %>
                <tr>
                    <td style="color: #28a745;"><strong>Descuento</strong></td>
                    <td class="monto" style="color: #28a745;">-$<%= descuento.toFixed(2) %></td>
                </tr>
                <tr>
                    <td><strong>Total</strong></td>
                    <td class="monto"><strong>$<%= total.toFixed(2) %></strong></td>
                </tr>
                <% } %>
                <% if (depositoPagado > 0 && totalPendiente > 0) { %>
                <tr>
                    <td>Depósito Pagado (25%)</td>
                    <td class="monto">$<%= depositoPagado.toFixed(2) %></td>
                </tr>
                <% } %>
            </tbody>
        </table>

        <div class="balance-pendiente">
            <span class="label">BALANCE PENDIENTE</span>
            <span class="importe <%= totalPendiente === 0 ? 'pagado' : '' %>">
                $<%= totalPendiente.toFixed(2) %>
            </span>
        </div>

        <% if (totalPendiente > 0) { %>
            <div class="mensaje-falta-pagar pendiente">
                FALTA PAGAR: <span class="monto">$<%= totalPendiente.toFixed(2) %></span>
            </div>
        <% } else { %>
            <div class="mensaje-falta-pagar pagado">
                TODO PAGADO
            </div>
        <% } %>

        <div class="estado-pago" style="border-color: <%= estadoColor %>; background: <%= estadoColor %>15;">
            <div class="texto" style="color: <%= estadoColor %>;">
                <%= estadoTexto %>
            </div>
        </div>

        <div class="resumen-pago">
            <div class="fila">
                <span class="label">Subtotal</span>
                <span class="value">$<%= subtotal.toFixed(2) %></span>
            </div>
            <% if (descuento > 0) { %>
            <div class="fila descuento">
                <span class="label">Descuento</span>
                <span class="value">-$<%= descuento.toFixed(2) %></span>
            </div>
            <div class="fila">
                <span class="label">Total</span>
                <span class="value">$<%= total.toFixed(2) %></span>
            </div>
            <% } %>
            <% if (depositoPagado > 0 && totalPendiente > 0) { %>
            <div class="fila">
                <span class="label">Depósito Pagado</span>
                <span class="value">$<%= depositoPagado.toFixed(2) %></span>
            </div>
            <% } %>
            <div class="fila total">
                <span class="label">Falta Pagar</span>
                <span class="value pendiente <%= totalPendiente === 0 ? 'pagado' : '' %>">
                    $<%= totalPendiente.toFixed(2) %>
                </span>
            </div>
        </div>

        <div class="qr-info">
            <span>Documento de verificación</span> - Código: <%= numeroRecibo %>
        </div>

        <div class="footer">
            <p class="empresa">Republic Excursions</p>
            <p>Punta Cana, República Dominicana</p>
            <p><%= fecha %></p>
            <p style="margin-top: 5px; font-size: 10px; color: #bbb;">Este documento es un comprobante de pago válido</p>
        </div>
    </div>
</body>
</html>
