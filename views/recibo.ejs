<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recibo <%= numeroRecibo %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            background: #e8e6e1;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .recibo {
            background: #ffffff;
            max-width: 800px;
            width: 100%;
            padding: 50px 55px;
            border-radius: 4px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            border: 1px solid #eae8e3;
        }

        /* ===== HEADER ===== */
        .header {
            text-align: center;
            border-bottom: 2px solid #1a2a4a;
            padding-bottom: 25px;
            margin-bottom: 30px;
        }

        .header .logo {
            font-size: 22px;
            font-weight: 700;
            color: #1a2a4a;
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .header .logo span {
            color: #c9a84c;
        }

        .header .titulo {
            font-size: 28px;
            font-weight: 400;
            color: #2c3e50;
            margin-top: 8px;
            letter-spacing: 2px;
        }

        .header .recibo-numero {
            font-size: 14px;
            color: #7f8c8d;
            margin-top: 6px;
            font-weight: 300;
            letter-spacing: 1px;
        }

        /* ===== DATOS DE LA RESERVA ===== */
        .info-cliente {
            margin-bottom: 30px;
            padding: 20px 25px;
            background: #f8f7f4;
            border-radius: 4px;
            border-left: 4px solid #c9a84c;
        }

        .info-cliente .titulo {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #7f8c8d;
            font-weight: 700;
            margin-bottom: 12px;
            border-bottom: 1px solid #eae8e3;
            padding-bottom: 8px;
        }

        .info-cliente .fila {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            font-size: 14px;
            color: #2c3e50;
            border-bottom: 1px solid #f0efeb;
        }

        .info-cliente .fila:last-child {
            border-bottom: none;
        }

        .info-cliente .label {
            font-weight: 600;
            color: #5d6d7e;
        }

        .info-cliente .valor {
            font-weight: 400;
            text-align: right;
            color: #1a2a4a;
        }

        /* ===== TABLA ===== */
        .tabla {
            width: 100%;
            border-collapse: collapse;
            margin: 25px 0;
            font-size: 14px;
            border-bottom: 2px solid #1a2a4a;
        }

        .tabla th {
            text-align: left;
            padding: 12px 0;
            border-bottom: 2px solid #1a2a4a;
            color: #1a2a4a;
            font-weight: 700;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .tabla td {
            padding: 10px 0;
            border-bottom: 1px solid #eae8e3;
            color: #2c3e50;
        }

        .tabla .monto {
            text-align: right;
            font-weight: 600;
        }

        .tabla .total {
            font-weight: 700;
            font-size: 16px;
        }

        .tabla .descuento {
            color: #27ae60;
        }

        /* ===== ESTADO DE PAGO ===== */
        .estado-unico {
            text-align: center;
            padding: 18px 20px;
            border-radius: 4px;
            margin: 25px 0;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .estado-unico.pagado {
            background: #eafaf1;
            border: 2px solid #27ae60;
            color: #1e8449;
        }

        .estado-unico.falta {
            background: #fef9e7;
            border: 2px solid #f1c40f;
            color: #7d6608;
        }

        .estado-unico.pendiente {
            background: #fdedec;
            border: 2px solid #e74c3c;
            color: #922b21;
        }

        .estado-unico .monto {
            font-size: 28px;
        }

        /* ===== RESUMEN ===== */
        .resumen-pago {
            background: #f8f7f4;
            padding: 18px 25px;
            border-radius: 4px;
            margin: 20px 0;
        }

        .resumen-pago .fila {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid #eae8e3;
            font-size: 14px;
        }

        .resumen-pago .fila:last-child {
            border-bottom: none;
        }

        .resumen-pago .label {
            font-weight: 600;
            color: #5d6d7e;
        }

        .resumen-pago .value {
            font-weight: 700;
            color: #1a2a4a;
        }

        .resumen-pago .value.pendiente {
            color: #e74c3c;
        }

        .resumen-pago .value.pagado {
            color: #27ae60;
        }

        .resumen-pago .fila.total {
            border-top: 2px solid #1a2a4a;
            padding-top: 10px;
            margin-top: 5px;
            font-size: 16px;
        }

        .resumen-pago .fila.descuento .value {
            color: #27ae60;
        }

        /* ===== FOOTER ===== */
        .footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #eae8e3;
            color: #95a5a6;
            font-size: 12px;
            letter-spacing: 1px;
        }

        .footer .empresa {
            color: #1a2a4a;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 2px;
        }

        .footer .direccion {
            margin-top: 4px;
            font-size: 11px;
            color: #bdc3c7;
        }

        .footer .codigo {
            margin-top: 6px;
            font-size: 10px;
            color: #bdc3c7;
            letter-spacing: 1px;
        }

        .qr-info {
            text-align: center;
            margin: 15px 0;
            padding: 10px;
            background: #f8f7f4;
            border-radius: 4px;
            font-size: 12px;
            color: #7f8c8d;
        }

        .qr-info span {
            font-weight: 700;
            color: #1a2a4a;
        }

        @media print {
            body {
                background: white;
                padding: 0;
            }
            .recibo {
                box-shadow: none;
                border: 1px solid #ddd;
                padding: 30px;
            }
        }

        @media (max-width: 600px) {
            .recibo {
                padding: 25px 20px;
            }
            .info-cliente .fila {
                flex-direction: column;
                align-items: flex-start;
            }
            .info-cliente .valor {
                text-align: left;
                width: 100%;
            }
            .tabla {
                font-size: 13px;
            }
            .estado-unico {
                font-size: 18px;
                padding: 14px;
            }
            .estado-unico .monto {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <div class="recibo">
        <!-- ===== HEADER ===== -->
        <div class="header">
            <div class="logo">Republic <span>Excursions</span></div>
            <div class="titulo">Recibo de Pago</div>
            <div class="recibo-numero">Recibo # <%= numeroRecibo %></div>
        </div>

        <!-- ===== DATOS DE LA RESERVA ===== -->
        <div class="info-cliente">
            <div class="titulo">Información de la Reserva</div>

            <div class="fila">
                <span class="label">Factura / Reserva</span>
                <span class="valor"><%= idFactura %></span>
            </div>
            <div class="fila">
                <span class="label">Cliente</span>
                <span class="valor"><%= cliente %></span>
            </div>
            <% if (whatsapp) { %>
            <div class="fila">
                <span class="label">WhatsApp</span>
                <span class="valor"><%= whatsapp %></span>
            </div>
            <% } %>
            <% if (correo) { %>
            <div class="fila">
                <span class="label">Correo Electrónico</span>
                <span class="valor"><%= correo %></span>
            </div>
            <% } %>
            <% if (hotel) { %>
            <div class="fila">
                <span class="label">Hotel</span>
                <span class="valor"><%= hotel %></span>
            </div>
            <% } %>
            <% if (habitacion) { %>
            <div class="fila">
                <span class="label">Habitación</span>
                <span class="valor"><%= habitacion %></span>
            </div>
            <% } %>
            <div class="fila">
                <span class="label">Excursión</span>
                <span class="valor"><%= excursion %></span>
            </div>
            <div class="fila">
                <span class="label">Fecha</span>
                <span class="valor"><%= fechaExcursion %></span>
            </div>
            <div class="fila">
                <span class="label">Personas</span>
                <span class="valor"><%= adultos %> Adultos, <%= ninos %> Niños</span>
            </div>
            <div class="fila">
                <span class="label">Transporte</span>
                <span class="valor"><%= transporte %></span>
            </div>
            <div class="fila">
                <span class="label">Método de Pago</span>
                <span class="valor"><%= metodoPago %></span>
            </div>
            <% if (notas && notas !== 'Sin notas adicionales') { %>
            <div class="fila">
                <span class="label">Notas</span>
                <span class="valor"><%= notas %></span>
            </div>
            <% } %>
        </div>

        <!-- ===== TABLA DE CONCEPTOS ===== -->
        <table class="tabla">
            <thead>
                <tr>
                    <th>Concepto</th>
                    <th class="monto">Monto (USD)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong><%= excursion %></strong></td>
                    <td class="monto"></td>
                </tr>
                <tr>
                    <td>Adultos: <%= adultos %> × $<%= precioAdulto.toFixed(2) %></td>
                    <td class="monto">$<%= (adultos * precioAdulto).toFixed(2) %></td>
                </tr>
                <% if (ninos > 0) { %>
                <tr>
                    <td>Niños: <%= ninos %> × $<%= precioNino.toFixed(2) %></td>
                    <td class="monto">$<%= (ninos * precioNino).toFixed(2) %></td>
                </tr>
                <% } %>
                <tr>
                    <td><strong>Subtotal</strong></td>
                    <td class="monto total">$<%= subtotal.toFixed(2) %></td>
                </tr>
                <% if (descuento > 0) { %>
                <tr>
                    <td style="color: #27ae60;"><strong>Descuento</strong></td>
                    <td class="monto descuento">-$<%= descuento.toFixed(2) %></td>
                </tr>
                <tr>
                    <td><strong>Total</strong></td>
                    <td class="monto total">$<%= total.toFixed(2) %></td>
                </tr>
                <% } %>
                <% if (depositoPagado > 0 && totalPendiente > 0) { %>
                <tr>
                    <td>Depósito Pagado (25%)</td>
                    <td class="monto">$<%= depositoPagado.toFixed(2) %></td>
                </tr>
                <% } %>
            </tbody>
        </table>

        <!-- ===== ESTADO DE PAGO ===== -->
        <% if (totalPendiente <= 0) { %>
            <div class="estado-unico pagado">
                Pagado Completo
            </div>
        <% } else if (estado === 'deposito') { %>
            <div class="estado-unico falta">
                Falta Pagar: <span class="monto">$<%= totalPendiente.toFixed(2) %></span>
            </div>
        <% } else { %>
            <div class="estado-unico pendiente">
                Pendiente de Pago: <span class="monto">$<%= totalPendiente.toFixed(2) %></span>
            </div>
        <% } %>

        <!-- ===== RESUMEN ===== -->
        <div class="resumen-pago">
            <div class="fila">
                <span class="label">Subtotal</span>
                <span class="value">$<%= subtotal.toFixed(2) %></span>
            </div>
            <% if (descuento > 0) { %>
            <div class="fila descuento">
                <span class="label">Descuento</span>
                <span class="value">-$<%= descuento.toFixed(2) %></span>
            </div>
            <div class="fila">
                <span class="label">Total</span>
                <span class="value">$<%= total.toFixed(2) %></span>
            </div>
            <% } %>
            <% if (depositoPagado > 0 && totalPendiente > 0) { %>
            <div class="fila">
                <span class="label">Depósito Pagado</span>
                <span class="value">$<%= depositoPagado.toFixed(2) %></span>
            </div>
            <% } %>
            <div class="fila total">
                <span class="label">Balance Pendiente</span>
                <span class="value pendiente <%= totalPendiente === 0 ? 'pagado' : '' %>">
                    $<%= totalPendiente.toFixed(2) %>
                </span>
            </div>
        </div>

        <!-- ===== CÓDIGO DE VERIFICACIÓN ===== -->
        <div class="qr-info">
            <span>Documento de verificación</span> &mdash; Código <%= numeroRecibo %>
        </div>

        <!-- ===== FOOTER ===== -->
        <div class="footer">
            <p class="empresa">Republic Excursions</p>
            <p class="direccion">Punta Cana, República Dominicana</p>
            <p><%= fecha %></p>
            <p class="codigo">Este documento es un comprobante de pago válido</p>
        </div>
    </div>
</body>
</html>
